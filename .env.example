FARS_APP_NAME=FARS Paper Knowledge Layer
FARS_APP_VERSION=0.1.0
FARS_ENVIRONMENT=development
FARS_API_PREFIX=/api
FARS_DATABASE_URL=sqlite+pysqlite:///./fars_kg.db
FARS_DATABASE_BOOTSTRAP_MODE=create_all
FARS_ALEMBIC_CONFIG_PATH=alembic.ini
FARS_ARTIFACTS_ROOT=.artifacts
FARS_ENABLE_REQUEST_LOGGING=true
FARS_REQUEST_ID_HEADER=X-Request-ID
FARS_LOG_LEVEL=INFO
FARS_OPERATOR_TOKEN=

FARS_OPENALEX_BASE_URL=https://api.openalex.org
FARS_OPENALEX_API_KEY=
FARS_OPENALEX_MAILTO=
FARS_OPENALEX_TIMEOUT_SECONDS=20.0

FARS_PARSER_PROVIDER=noop
FARS_GROBID_BASE_URL=http://localhost:8070
FARS_GROBID_TIMEOUT_SECONDS=60.0

FARS_REPO_ROOT=.
FARS_WORKTREE_ROOT=.worktrees
